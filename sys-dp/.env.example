# Banco de dados PostgreSQL
DATABASE_URL="postgresql://usuario:senha@localhost:5432/sys_dp?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="gere-uma-chave-secreta-com-openssl-rand-base64-32"
# AUTH_SECRET deve ter o mesmo valor que NEXTAUTH_SECRET (NextAuth v5)
AUTH_SECRET="gere-uma-chave-secreta-com-openssl-rand-base64-32"
# Necessário em produção (Vercel, Railway, etc) para aceitar o host da request
AUTH_TRUST_HOST="true"

# Criptografia (AES-256 para certificados digitais)
ENCRYPTION_KEY="chave-de-32-bytes-para-aes-256"

# eSocial (ambiente)
ESOCIAL_AMBIENTE="2" # 1=Produção, 2=Homologação
ESOCIAL_URL_PRODUCAO="https://webservices.producao.esocial.gov.br"
ESOCIAL_URL_HOMOLOGACAO="https://webservices.homologacao.esocial.gov.br"

# Redis (filas eSocial e relatórios)
REDIS_URL="redis://localhost:6379"

# Storage (MinIO / S3)
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="sys-dp"

# Email
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="seu@email.com"
SMTP_PASS="senha-app"
SMTP_FROM="SYS-DP <noreply@seusistema.com.br>"
